# -----------------------------
# Dependency directories
# -----------------------------
node_modules/
**/node_modules/
venv/
**/venv/

# -----------------------------
# Build artifacts
# -----------------------------
dist/
**/dist/
build/
**/build/
.next/
.turbo/

# -----------------------------
# Python cache/compiled files
# -----------------------------
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd

# -----------------------------
# Environment/secrets
# -----------------------------
.env
.env.*
!.env.example
*.local

# -----------------------------
# Generated outputs
# Keep outputs folder but ignore generated text files
# -----------------------------
outputs/*.txt
**/outputs/*.txt

# -----------------------------
# Logs/temp files
# -----------------------------
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
*.tmp
*.temp

# -----------------------------
# IDE/editor files
# -----------------------------
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.user
*.swp
*.swo

# -----------------------------
# OS/system-generated files
# -----------------------------
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
.Spotlight-V100/
.Trashes/
