# Backend server
PORT=8000

# LLM setup
# Use "ollama" for local laptop development.
# Use "openai_compatible" for cloud deployment (OpenAI/Groq/OpenRouter style APIs).
LLM_BACKEND=openai_compatible
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free
LLM_API_KEY=your_api_key_here

# If you run locally with Ollama, use:
# LLM_BACKEND=ollama
# LLM_BASE_URL=http://127.0.0.1:11434
# LLM_MODEL=gemma3:4b
